{
	"name": "@chillwhales/lsps",
	"private": true,
	"description": "LUKSO Standards Packages — TypeScript implementations of LSP standards",
	"license": "MIT",
	"author": "b00ste",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/chillwhales/LSPs.git"
	},
	"bugs": {
		"url": "https://github.com/chillwhales/LSPs/issues"
	},
	"keywords": [
		"lukso",
		"lsp",
		"typescript",
		"blockchain",
		"chillwhales"
	],
	"scripts": {
		"build": "pnpm -r build",
		"changeset": "changeset",
		"ci:publish": "changeset publish",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "pnpm -r clean",
		"preinstall": "npx only-allow pnpm",
		"check:lint": "biome check",
		"check:lint:fix": "biome check --write",
		"knip": "knip",
		"sherif": "sherif",
		"madge": "madge --circular --extensions ts --exclude '\\.test\\.ts$' --ts-config ./packages/config/tsconfig.base.json packages/*/src",
		"deps:graph": "pnpm madge --image deps-graph.svg",
		"typecheck": "pnpm -r --filter './packages/*' --filter '!@chillwhales/config' exec tsc --noEmit",
		"check": "pnpm check:lint && pnpm sherif && pnpm knip && pnpm madge",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "npx @biomejs/biome check --write --staged --files-ignore-unknown=true --no-errors-on-unmatched && git update-index --again",
		"commit-msg": "npx commitlint --edit $1"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@biomejs/biome": "^2.4.6",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"@vitest/coverage-v8": "^4.0.18",
		"knip": "^5.85.0",
		"madge": "^8.0.0",
		"only-allow": "^1.2.2",
		"publint": "^0.3.18",
		"sherif": "^1.10.0",
		"simple-git-hooks": "^2.13.1",
		"vitest": "catalog:"
	},
	"sherif": {
		"failOnWarnings": true
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"simple-git-hooks"
		]
	},
	"packageManager": "pnpm@10.30.2",
	"engines": {
		"node": ">=22"
	}
}
